# Blockchain Configuration
PRIVATE_KEY=your_private_key_here
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
INFURA_API_KEY=your_infura_api_key_here

# Etherscan API (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Wallet Addresses
TREASURY_WALLET=0xYourTreasuryWalletAddress
ARTIST_WALLET=0xArtistWalletAddress

# Campaign Configuration
ARTIST_NAME=Drake Concert 2026
FUNDING_GOAL=1200
BASE_TOKEN_URI=ipfs://QmYourBaseURI

# Gas Reporting (optional)
REPORT_GAS=false
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Frontend Configuration
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_ITMV_TOKEN_ADDRESS=
NEXT_PUBLIC_CAMPAIGN_FACTORY_ADDRESS=
NEXT_PUBLIC_CAMPAIGN_ID=0

# The Graph
NEXT_PUBLIC_SUBGRAPH_URL=https://api.studio.thegraph.com/query/YOUR_SUBGRAPH

# IPFS (Pinata or NFT.Storage)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
NFT_STORAGE_API_KEY=your_nft_storage_api_key

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
